{
  "$schema": "https://json.schemastore.org/prettierrc",
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "printWidth": 120,
  "proseWrap": "preserve",
  "semi": true,
  "singleQuote": true,
  "tabWidth": 4,
  "trailingComma": "none",
  "useTabs": false,
  "overrides": [
    {
      "files": ["*.yml", "*.yaml", "*.json", "*.jsonc", "*.md"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
