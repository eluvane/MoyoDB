{
  "name": "moyodb-repo",
  "version": "0.1.0",
  "private": true,
  "description": "Repository-level quality gates for the MoyoDB mixed TypeScript/Rust/Lean workspace.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/sdk"
  ],
  "scripts": {
    "format": "npm run format:prettier && npm run format:toml && npm run format:rust",
    "format:prettier": "prettier --config .config/moyo/formatters/prettier.json --ignore-path .config/moyo/formatters/prettierignore --write .",
    "format:toml": "taplo fmt --config .config/moyo/formatters/taplo.toml \"**/*.toml\"",
    "format:rust": "cargo fmt --all -- --config-path .config/moyo/formatters/rustfmt.toml",
    "format:check": "npm run format:check:prettier && npm run format:check:biome && npm run format:check:toml && npm run format:check:rust",
    "format:check:prettier": "prettier --config .config/moyo/formatters/prettier.json --ignore-path .config/moyo/formatters/prettierignore --check .",
    "format:check:biome": "biome ci --config-path .config/moyo/formatters/biome.jsonc .",
    "format:check:toml": "taplo fmt --config .config/moyo/formatters/taplo.toml --check \"**/*.toml\"",
    "format:check:rust": "cargo fmt --all -- --check --config-path .config/moyo/formatters/rustfmt.toml",
    "typecheck": "npm run typecheck --workspace @moyodb/sdk",
    "lint": "npm run lint:typescript && npm run lint:rust && npm run lint:lean && npm run lint:repo",
    "lint:typescript": "npm run typecheck && npm run lint:eslint && npm run lint:oxlint && npm run lint:biome && npm run lint:dependency-cruiser",
    "lint:eslint": "eslint --config .config/moyo/lints/eslint.config.mjs packages/sdk/src packages/sdk/tests packages/sdk/bench packages/sdk/*.ts",
    "lint:oxlint": "oxlint --config .config/moyo/lints/oxlint.json .",
    "lint:biome": "biome ci --config-path .config/moyo/formatters/biome.jsonc .",
    "lint:dependency-cruiser": "depcruise --config .config/moyo/lints/dependency-cruiser.cjs packages/sdk/src packages/sdk/tests packages/sdk/bench packages/sdk/scripts packages/sdk/vite.config.ts packages/sdk/playwright.config.ts",
    "lint:rust": "node .config/moyo/quality/run-clippy.mjs && cargo machete --with-metadata",
    "lint:lean": "node .config/moyo/quality/check-lean-hygiene.mjs && cd proofs/moyodb_proofs && lake build --wfail MoyoDbProofs && lake lint --builtin-lint && lake env leanchecker --fresh MoyoDbProofs",
    "lint:repo": "npm run lint:markdown && npm run lint:yaml && npm run lint:toml && npm run lint:actions && npm run lint:workflows && npm run lint:package-json && npm run lint:names && npm run lint:json",
    "lint:markdown": "markdownlint-cli2 --config .config/moyo/lints/markdownlint-cli2.jsonc \"**/*.md\"",
    "lint:yaml": "python -m yamllint -c .config/moyo/lints/yamllint.yml .",
    "lint:toml": "taplo lint --config .config/moyo/formatters/taplo.toml \"**/*.toml\"",
    "lint:actions": "node .config/moyo/ci/run-actionlint.mjs",
    "lint:package-json": "npmPkgJsonLint --configFile .config/moyo/lints/npm-package-json-lint.json --ignorePath .config/moyo/formatters/prettierignore .",
    "lint:names": "ls-lint --config .config/moyo/lints/ls-lint.yml",
    "lint:json": "node .config/moyo/quality/check-json-files.mjs",
    "quality": "npm run quality:knip && npm run quality:syncpack && npm run quality:package-manager && npm run quality:docs",
    "quality:knip": "knip --config .config/moyo/lints/knip.json",
    "quality:syncpack": "syncpack lint --config .config/moyo/lints/syncpack.config.cjs",
    "quality:package-manager": "node .config/moyo/quality/check-package-manager.mjs",
    "quality:docs": "node .config/moyo/quality/check-docs-links.mjs",
    "security": "npm run security:npm-audit && npm run security:cargo-deny && npm run security:gitleaks && npm run security:semgrep",
    "security:npm-audit": "npm audit --audit-level=high",
    "security:cargo-deny": "cargo deny check --config .config/moyo/security/cargo-deny.toml",
    "security:gitleaks": "gitleaks detect --no-git --source . --config .config/moyo/security/gitleaks.toml --redact --verbose",
    "security:semgrep": "semgrep scan --config .config/moyo/security/semgrep.yml --error --no-git-ignore .",
    "test": "npm run test:rust && npm run test:sdk",
    "test:rust": "cargo test --workspace --all-targets",
    "test:sdk": "npm run test:e2e --workspace @moyodb/sdk",
    "build": "npm run build --workspace @moyodb/sdk",
    "check": "npm run format:check && npm run lint && npm run quality && npm run security",
    "check:all": "npm run check && npm run test && npm run build",
    "lint:workflows": "node .config/moyo/quality/check-workflows.mjs",
    "security:osv": "osv-scanner scan source --config .config/moyo/security/osv-scanner.toml -r .",
    "security:paranoid": "npm run security && npm run security:osv",
    "bench": "npm run bench:collect:smoke",
    "bench:rust": "cargo bench --workspace",
    "bench:rust:compile": "cargo bench --workspace --no-run",
    "bench:browser": "npm run bench:browser --workspace @moyodb/sdk",
    "bench:indexeddb": "npm run bench:indexeddb --workspace @moyodb/sdk",
    "bench:opfs": "npm run bench:opfs --workspace @moyodb/sdk",
    "bench:report": "npm run bench:report --workspace @moyodb/sdk",
    "bench:collect": "node scripts/benchmark/collect.mjs",
    "bench:collect:smoke": "node scripts/benchmark/collect.mjs --smoke",
    "bench:collect:from-results": "node scripts/benchmark/collect.mjs --from-results",
    "bench:compare": "node scripts/benchmark/compare.mjs",
    "bench:compare:gate": "node scripts/benchmark/compare.mjs --fail-on-regression",
    "bench:governance:smoke": "node scripts/benchmark/collect.mjs --smoke --skip-browser --out-dir .benchmark/smoke",
    "check:paranoid": "npm run check:all && npm run security:osv",
    "ci": "npm run check:all"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@eslint/js": "10.0.1",
    "@ls-lint/ls-lint": "2.3.1",
    "@taplo/cli": "0.7.0",
    "@typescript/native": "npm:typescript@7.0.2",
    "actionlint": "2.0.6",
    "dependency-cruiser": "18.1.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.0",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-unicorn": "71.1.0",
    "globals": "17.7.0",
    "knip": "6.20.0",
    "markdownlint-cli2": "0.22.1",
    "npm-package-json-lint": "10.4.1",
    "oxlint": "1.71.0",
    "prettier": "3.8.4",
    "syncpack": "15.3.2",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "8.62.0"
  },
  "overrides": {
    "js-yaml": "4.2.0",
    "markdown-it": "14.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/moyodb/moyodb.git"
  },
  "keywords": [
    "moyodb",
    "rust",
    "typescript",
    "lean",
    "wasm",
    "database",
    "quality-gate"
  ]
}
